generator client {
  provider                    = "prisma-client-py"
  enable_experimental_decimal = true
  recursive_type_depth        = -1
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// --------------------
/// User investment objective (both structured and raw json)
/// --------------------
model Objective {
  id                       String   @id @default(uuid())
  user_id                  String
  name                     String?
  raw                      Json     @default("{}")
  investable_amount        Decimal  @db.Decimal(20, 4)
  investment_horizon_years Int
  liquidity_needs          String?
  rebalancing_frequency    String?
  constraints              Json?    @default("{}")
  target_returns           Json?    @default("[]")
  status                   String   @default("active")
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  portfolios Portfolio[]

  @@index([user_id])
  @@map("objectives")
}

/// --------------------
/// Portfolio (modified)
/// --------------------
model Portfolio {
  id                       String    @id @default(uuid())
  id                       String    @id @default(uuid())
  user_id                  String?
  objective_id             String?
  organization_id          String
  customer_id              String
  portfolio_name           String
  initial_investment       Decimal   @db.Decimal(20, 4)
  investment_amount        Decimal   @db.Decimal(20, 4)
  current_value            Decimal   @default(0) @db.Decimal(20, 4)
  initial_investment       Decimal   @db.Decimal(20, 4)
  investment_amount        Decimal   @db.Decimal(20, 4)
  current_value            Decimal   @default(0) @db.Decimal(20, 4)
  investment_horizon_years Int
  expected_return_target   Decimal   @db.Decimal(7, 4)
  expected_return_target   Decimal   @db.Decimal(7, 4)
  risk_tolerance           String
  liquidity_needs          String
  rebalancing_frequency    Json?
  allocation_strategy      Json?
  constraints              Json?
  status                   String    @default("active")
  allocation_status        String    @default("pending") // pending, processing, ready, failed
  rebalancing_date         DateTime? // Next date when portfolio should be rebalanced
  last_rebalanced_at       DateTime?
  next_rebalance_at        DateTime?
  metadata                 Json?     @default("{}")
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt
  metadata                 Json?     @default("{}")
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt
  deleted_at               DateTime?

  allocations    PortfolioAllocation[]
  trades         Trade[]
  positions      Position[]
  agents         TradingAgent[]
  rebalance_runs RebalanceRun[]
  allocations    PortfolioAllocation[]
  trades         Trade[]
  positions      Position[]
  agents         TradingAgent[]
  rebalance_runs RebalanceRun[]

  objective Objective? @relation(fields: [objective_id], references: [id], onDelete: SetNull)
  objective Objective? @relation(fields: [objective_id], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([customer_id])
  @@index([status])
  @@index([user_id])
  @@map("portfolios")
}

/// --------------------
/// Portfolio allocation
/// --------------------
model PortfolioAllocation {
  id                   String   @id @default(uuid())
  portfolio_id         String
  allocation_type      String // "alpha_agent", "high_risk", "low_risk"
  target_weight        Decimal  @db.Decimal(9, 6)
  current_weight       Decimal  @default(0) @db.Decimal(9, 6)
  allocated_amount     Decimal  @default(0) @db.Decimal(20, 4)
  current_value        Decimal  @default(0) @db.Decimal(20, 4)
  expected_return      Decimal? @db.Decimal(9, 6) // From Pathway allocation pipeline
  expected_risk        Decimal? @db.Decimal(9, 6) // From Pathway allocation pipeline
  regime               String? // Market regime at allocation time
  pnl                  Decimal  @default(0) @db.Decimal(20, 4)
  pnl_percentage       Decimal  @default(0) @db.Decimal(9, 6)
  drift_percentage     Decimal  @default(0) @db.Decimal(9, 6)
  requires_rebalancing Boolean  @default(false)
  metadata             Json?    @default("{}")
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  portfolio            Portfolio            @relation(fields: [portfolio_id], references: [id], onDelete: Cascade)
  tradingAgent         TradingAgent?        @relation("AllocationAgent")
  portfolio            Portfolio            @relation(fields: [portfolio_id], references: [id], onDelete: Cascade)
  tradingAgent         TradingAgent?        @relation("AllocationAgent")
  allocation_snapshots AllocationSnapshot[]

  @@index([portfolio_id])
  @@index([allocation_type])
  @@map("portfolio_allocations")
}

/// --------------------
/// Trading agent
/// --------------------
model TradingAgent {
  id                      String    @id @default(uuid())
  portfolio_id            String? // Optional portfolio reference for direct agent-portfolio link
  portfolio_allocation_id String
  agent_type              String
  agent_name              String
  status                  String    @default("active")
  status                  String    @default("active")
  strategy_config         Json?
  performance_metrics     Json?
  last_executed_at        DateTime?
  error_count             Int       @default(0)
  error_count             Int       @default(0)
  last_error_message      String?
  metadata                Json?     @default("{}")
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
  metadata                Json?     @default("{}")
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  portfolio  Portfolio?          @relation(fields: [portfolio_id], references: [id], onDelete: Cascade)
  allocation PortfolioAllocation @relation("AllocationAgent", fields: [portfolio_allocation_id], references: [id], onDelete: Cascade)
  trades     Trade[]
  positions  Position[]

  @@unique([portfolio_allocation_id])
  @@index([portfolio_id])
  @@index([portfolio_allocation_id])
  @@index([agent_type])
  @@map("trading_agents")
}

/// --------------------
/// Trades
/// --------------------
model Trade {
  id                String    @id @default(uuid())
  id                String    @id @default(uuid())
  organization_id   String
  portfolio_id      String
  agent_id          String?
  customer_id       String
  trade_type        String
  symbol            String
  exchange          String
  segment           String
  side              String
  order_type        String
  quantity          Int
  limit_price       Decimal?  @db.Decimal(20, 4)
  price             Decimal?  @db.Decimal(20, 4)
  trigger_price     Decimal?  @db.Decimal(20, 4)
  executed_quantity Int       @default(0)
  executed_price    Decimal?  @db.Decimal(20, 4)
  status            String    @default("pending")
  limit_price       Decimal?  @db.Decimal(20, 4)
  price             Decimal?  @db.Decimal(20, 4)
  trigger_price     Decimal?  @db.Decimal(20, 4)
  executed_quantity Int       @default(0)
  executed_price    Decimal?  @db.Decimal(20, 4)
  status            String    @default("pending")
  order_id          String?
  execution_time    DateTime?
  rejection_reason  String?
  fees              Decimal?  @db.Decimal(20, 4)
  taxes             Decimal?  @db.Decimal(20, 4)
  net_amount        Decimal?  @db.Decimal(20, 4)
  fees              Decimal?  @db.Decimal(20, 4)
  taxes             Decimal?  @db.Decimal(20, 4)
  net_amount        Decimal?  @db.Decimal(20, 4)
  source            String?
  metadata          Json?     @default("{}")
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  metadata          Json?     @default("{}")
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  portfolio Portfolio     @relation(fields: [portfolio_id], references: [id], onDelete: Cascade)
  agent     TradingAgent? @relation(fields: [agent_id], references: [id])

  @@index([organization_id])
  @@index([portfolio_id])
  @@index([customer_id])
  @@index([status])
  @@map("trades")
}

/// --------------------
/// Positions
/// --------------------
model Position {
  id                String    @id @default(uuid())
  id                String    @id @default(uuid())
  portfolio_id      String
  agent_id          String?
  symbol            String
  exchange          String
  segment           String
  quantity          Int
  average_buy_price Decimal   @db.Decimal(20, 4)
  current_price     Decimal   @db.Decimal(20, 4)
  current_value     Decimal   @db.Decimal(20, 4)
  pnl               Decimal   @default(0) @db.Decimal(20, 4)
  pnl_percentage    Decimal   @default(0) @db.Decimal(9, 6)
  average_buy_price Decimal   @db.Decimal(20, 4)
  current_price     Decimal   @db.Decimal(20, 4)
  current_value     Decimal   @db.Decimal(20, 4)
  pnl               Decimal   @default(0) @db.Decimal(20, 4)
  pnl_percentage    Decimal   @default(0) @db.Decimal(9, 6)
  position_type     String
  status            String    @default("open")
  status            String    @default("open")
  opened_at         DateTime?
  closed_at         DateTime?
  metadata          Json?     @default("{}")
  updated_at        DateTime  @updatedAt
  metadata          Json?     @default("{}")
  updated_at        DateTime  @updatedAt

  portfolio Portfolio     @relation(fields: [portfolio_id], references: [id], onDelete: Cascade)
  agent     TradingAgent? @relation(fields: [agent_id], references: [id])

  @@index([portfolio_id])
  @@index([agent_id])
  @@index([status])
  @@map("positions")
}

/// --------------------
/// Rebalance run
/// --------------------
model RebalanceRun {
  id                       String   @id @default(uuid())
  portfolio_id             String
  triggered_by             String?
  triggered_at             DateTime @default(now())
  snapshot_portfolio_value Decimal  @db.Decimal(20, 4)
  snapshot_cash            Decimal  @db.Decimal(20, 4)
  snapshot_invested        Decimal  @db.Decimal(20, 4)
  time_elapsed_days        Int?
  expected_progress        Json?
  metadata                 Json?    @default("{}")
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  id                       String   @id @default(uuid())
  portfolio_id             String
  triggered_by             String?
  triggered_at             DateTime @default(now())
  snapshot_portfolio_value Decimal  @db.Decimal(20, 4)
  snapshot_cash            Decimal  @db.Decimal(20, 4)
  snapshot_invested        Decimal  @db.Decimal(20, 4)
  time_elapsed_days        Int?
  expected_progress        Json?
  metadata                 Json?    @default("{}")
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  portfolio            Portfolio            @relation(fields: [portfolio_id], references: [id], onDelete: Cascade)
  segment_snapshots    SegmentSnapshot[]
  portfolio            Portfolio            @relation(fields: [portfolio_id], references: [id], onDelete: Cascade)
  segment_snapshots    SegmentSnapshot[]
  allocation_snapshots AllocationSnapshot[]

  @@index([portfolio_id])
  @@map("rebalance_runs")
}

/// --------------------
/// Segment snapshot
/// --------------------
model SegmentSnapshot {
  id               String   @id @default(uuid())
  rebalance_run_id String
  segment_key      String
  allocated_amount Decimal  @db.Decimal(20, 4)
  liquid_amount    Decimal  @db.Decimal(20, 4)
  invested_amount  Decimal  @db.Decimal(20, 4)
  return_pct       Decimal  @db.Decimal(9, 6)
  volatility       Decimal  @db.Decimal(9, 6)
  max_drawdown     Decimal  @db.Decimal(9, 6)
  sharpe_ratio     Decimal? @db.Decimal(9, 6)
  metrics          Json?    @default("{}")
  created_at       DateTime @default(now())

  rebalance_run RebalanceRun @relation(fields: [rebalance_run_id], references: [id], onDelete: Cascade)

  @@index([rebalance_run_id])
  @@index([segment_key])
  @@map("segment_snapshots")
}

/// --------------------
/// Allocation snapshot
/// --------------------
model AllocationSnapshot {
  id                      String   @id @default(uuid())
  rebalance_run_id        String
  portfolio_allocation_id String
  snapshot_weight         Decimal  @db.Decimal(9, 6)
  snapshot_amount         Decimal  @db.Decimal(20, 4)
  snapshot_current_value  Decimal  @db.Decimal(20, 4)
  snapshot_pnl            Decimal  @db.Decimal(20, 4)
  metadata                Json?    @default("{}")
  created_at              DateTime @default(now())

  rebalance_run        RebalanceRun        @relation(fields: [rebalance_run_id], references: [id], onDelete: Cascade)
  rebalance_run        RebalanceRun        @relation(fields: [rebalance_run_id], references: [id], onDelete: Cascade)
  portfolio_allocation PortfolioAllocation @relation(fields: [portfolio_allocation_id], references: [id], onDelete: Cascade)

  @@index([rebalance_run_id])
  @@index([portfolio_allocation_id])
  @@map("allocation_snapshots")
}
