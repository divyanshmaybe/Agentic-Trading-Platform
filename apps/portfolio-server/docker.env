PORT=8000
NODE_ENV=production
DATABASE_URL=postgresql://portfolio_user:portfolio_password@portfolio-postgres:5432/portfolio_db
SHADOW_DATABASE_URL=postgresql://portfolio_user:portfolio_password@portfolio-postgres:5432/portfolio_db
INTERNAL_SERVICE_SECRET=agentinvest-secret
AUTH_SERVER_URL=http://auth_server:4000
PORTFOLIO_SERVICE_URL=http://portfolio_server:8000
REDIS_HOST=portfolio-redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://portfolio-redis:6379/0
CELERY_RESULT_BACKEND=redis://portfolio-redis:6379/1

ENABLE_NIFTY500_PREFETCH=false

