PORT=8000
NODE_ENV=production
DATABASE_URL=postgresql://portfolio_user:portfolio_password@portfolio_postgres:5432/portfolio_db
SHADOW_DATABASE_URL=postgresql://portfolio_user:portfolio_password@portfolio_postgres:5432/portfolio_db
INTERNAL_SERVICE_SECRET=agentinvest-secret
AUTH_SERVER_URL=http://auth_server:4000
PORTFOLIO_SERVICE_URL=http://portfolio_server:8000
REDIS_HOST=portfolio_redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://portfolio_redis:6379/0
CELERY_RESULT_BACKEND=redis://portfolio_redis:6379/1
ENABLE_NIFTY500_PREFETCH=false

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=portfolio-server
KAFKA_ENABLED=true

# Prisma Connection Pool Settings
# Lower limits for Celery workers to prevent exhaustion
PRISMA_CONNECTION_LIMIT=3
PRISMA_POOL_TIMEOUT=10

# Angel One credentials (from root .env)
# ANGELONE_CLIENT_CODE=
# ANGELONE_API_KEY=
# ANGELONE_PASSWORD=
# ANGELONE_TOTP_SECRET=

# Gemini API keys (from root .env)
# GEMINI_API_KEY=

