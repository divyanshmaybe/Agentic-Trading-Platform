{
	"name": "@portfolio/server",
	"version": "1.0.0",
	"private": true,
	"description": "Portfolio Server - FastAPI server with NSE pipeline integration",
	"scripts": {
		"setup": "VENV_BIN=${VENV_BIN:-$(pwd)/.venv/bin} && \"$VENV_BIN/pip\" install -r requirements.txt && PATH=\"$VENV_BIN:$PATH\" \"$VENV_BIN/prisma\" generate",
		"prisma:generate": "VENV_BIN=${VENV_BIN:-$(pwd)/.venv/bin} && PATH=\"$VENV_BIN:$PATH\" \"$VENV_BIN/prisma\" generate",
		"dev": "PYTHONPATH=../../shared/py ./.venv/bin/python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
		"celery": "PYTHONPATH=../../shared/py:../../middleware/py ./.venv/bin/celery -A celery_app:celery_app worker --loglevel=info"
	},
	"dependencies": {},
	"devDependencies": {}
}