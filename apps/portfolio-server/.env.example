# API Keys
GEMINI_API_KEY=your_gemini_api_key
NEWS_ORG_API_KEY=your_news_org_api_key
SERP_API_KEY=your_serp_api_key
GROQ_API_KEY=your_groq_api_key

# Portfolio Settings
DEFAULT_PORTFOLIO_CASH=100000
MAX_TRADE_VALUE=250000
MAX_POSITION_VALUE=1000000

# Angel One Market Data Configuration
MARKET_DATA_PROVIDER=angelone
ANGELONE_WS_URL=wss://smartapisocket.angelone.in/smart-stream
ANGELONE_CLIENT_CODE=your_client_code
ANGELONE_API_KEY=your_api_key
ANGELONE_PASSWORD=your_password
ANGELONE_TOTP_SECRET=your_totp_secret
# Token map is auto-generated and cached in apps/portfolio-server/docs/angelone_tokens.json

# Demo Mode - Bypass market hours restrictions
# When set to "true", the NSE pipeline will process signals 24/7 regardless of market hours
# Useful for testing and demonstrations outside trading hours
DEMO_MODE=false

# Database Connection Pool Settings (CRITICAL for production)
# PRISMA_CONNECTION_LIMIT: Max connections per Prisma client instance
# Recommended: 3 (with CELERY_WORKER_CONCURRENCY=4 → 3×4=12 connections per process)
# WARNING: Too high will exhaust PostgreSQL max_connections (default: 100)
PRISMA_CONNECTION_LIMIT=3
PRISMA_POOL_TIMEOUT=10

# Celery Worker Configuration (CRITICAL for production)
# CELERY_WORKER_CONCURRENCY: Number of concurrent worker threads
# Recommended: 4 (down from default 8 to prevent connection exhaustion)
# Calculation: 3 connections × 4 workers = 12 per process (safe for 100 max)
CELERY_WORKER_CONCURRENCY=4
# Worker recycling to prevent memory leaks and zombie processes
CELERY_MAX_TASKS_PER_CHILD=50