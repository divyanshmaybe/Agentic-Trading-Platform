# AlphaCopilot Server Environment Variables

# Server Configuration
PORT=8069
HOST=0.0.0.0

# Database Configuration
DATABASE_URL=postgresql://portfolio_user:portfolio_password@localhost:5432/portfolio_db

# Redis Configuration
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MLflow Configuration
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=alphacopilot

# Groww API (market data scripts)
TOTP_TOKEN=your_groww_totp_token
TOTP_SECRET=your_groww_totp_secret

# LLM Configuration
LLM_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Quant-Stream Configuration
QLIB_DATA_PATH=../../quant-stream/.data/qlib

# Internal Service Authentication
INTERNAL_SERVICE_SECRET=your-internal-secret-change-in-production

# Workflow Configuration
MAX_ITERATIONS=3
DEFAULT_MODEL_TYPE=LightGBM

# CORS Configuration (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9108
