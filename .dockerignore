# Global Docker build ignores
.git
.gitignore
.gitmodules
.github/

# =====================
# Environment files - CRITICAL: prevent .env from overriding Docker env vars
# =====================
.env
.env.*
.env.local
.env.development
.env.production
.env.test
**/.env
**/.env.*
**/.env.local
apps/**/.env
apps/**/.env.*
shared/**/.env
shared/**/.env.*

# =====================
# Python artifacts
# =====================
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
**/.pytest_cache/
.mypy_cache/
**/.mypy_cache/
.coverage
**/.coverage
.venv/
venv/
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# =====================
# Node / frontend artifacts
# =====================
node_modules/
**/node_modules/
.next/
**/.next/
.turbo/
**/.turbo/
.cache/
**/.cache/
*.tsbuildinfo
**/*.tsbuildinfo

# =====================
# Build outputs
# =====================
dist/
build/
out/
coverage/
**/coverage/

# =====================
# Test files
# =====================
tests/
**/tests/
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/*.spec.js
__tests__/
**/__tests__/
pytest.ini
setup.cfg
tox.ini

# =====================
# Documentation
# =====================
docs/
*.md
!README.md
LICENSE

# =====================
# Logs and temporary files
# =====================
*.log
**/*.log
logs/
**/logs/
tmp/
**/tmp/
temp/
**/temp/
celerybeat-schedule
celerybeat-schedule.*

# =====================
# IDE and OS files
# =====================
.DS_Store
**/.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# =====================
# Docker related
# =====================
docker-compose.override.yml
docker-compose.*.yml
!docker-compose.yml
Dockerfile*
!apps/*/Dockerfile
.docker/

# =====================
# Project-specific scripts not needed in images
# =====================
kafkaStudio.py
push_*.py
push_*.sh
*.sh
!setup.sh
Makefile

# =====================
# Data and scripts folders not needed
# =====================
data/
apps/data/
scripts/
devops/
docker_manifests/

# =====================
# Development / Debug tools
# =====================
.nyc_output/
.scannerwork/
.sonar/

# =====================
# Package manager files (use lock files only)
# =====================
package-lock.json
yarn.lock

# =====================
# Misc
# =====================
*.csv
*.pdf
*.zip
*.tar.gz

