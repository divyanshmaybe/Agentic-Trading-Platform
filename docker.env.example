# Root Docker Environment Variables
# These variables are used when running services in Docker containers

# =============================================================================
# IMPORTANT: Copy this file to docker.env and update with your actual values
# =============================================================================

# Service URLs (internal Docker network)
AUTH_SERVER_URL=http://auth_server:4000
PORTFOLIO_SERVER_URL=http://portfolio_server:8000
ALPHACOPILOT_SERVER_URL=http://alphacopilot_server:8069
NOTIFICATION_SERVER_URL=http://notification_server:8099
CLIENT_URL=http://frontend:3000

# Database URLs (Docker service names)
AUTH_DATABASE_URL=postgresql://auth_user:auth_password@postgres:5432/auth_db
PORTFOLIO_DATABASE_URL=postgresql://portfolio_user:portfolio_password@portfolio_postgres:5432/portfolio_db

# Redis URLs (Docker service names)
AUTH_REDIS_URL=redis://redis:6379
PORTFOLIO_REDIS_URL=redis://portfolio_redis:6379

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# JWT Secrets (Generate strong random values for production)
JWT_SECRET_ACCESS=change-this-in-production-use-long-random-string
JWT_SECRET_REFRESH=change-this-in-production-use-long-random-string
JWT_SECRET_EMAIL=change-this-in-production-use-long-random-string
INTERNAL_SERVICE_SECRET=change-this-in-production-use-long-random-string
SESSION_SECRET=change-this-in-production-use-long-random-string

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDER_EMAIL_ADDRESS=noreply@yourdomain.com

# LLM API Keys
GEMINI_API_KEY=your-gemini-api-key-here
LLM_API_KEY=your-openai-api-key-here

# News API
NEWSAPI_KEY=your-newsapi-key-here

# Angel One Broker Configuration
ANGEL_ONE_API_KEY=your-angelone-api-key
ANGEL_ONE_CLIENT_CODE=your-client-code
ANGEL_ONE_PASSWORD=your-password
ANGEL_ONE_TOTP_SECRET=your-totp-secret
MARKET_DATA_PROVIDER=angelone

# Feature Flags
DEMO_MODE=false
STREAMING_RISK_MONITOR_ENABLED=true
PORTFOLIO_REBALANCE_ENABLED=true
NSE_PIPELINE_RUN_ON_STARTUP=true
NEWS_PIPELINE_RUN_ON_STARTUP=true
ALLOCATION_SWEEP_ON_STARTUP=true

# Next.js Frontend Configuration
NEXT_PUBLIC_AUTH_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_PORTFOLIO_SERVER_URL=http://localhost:8000
NEXT_PUBLIC_ALPHACOPILOT_SERVER_URL=http://localhost:8069
NEXT_PUBLIC_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
NEXT_PUBLIC_ENABLE_COPILOT=true
NEXT_PUBLIC_ENABLE_ADMIN=true

# MLflow Configuration
MLFLOW_TRACKING_URI=./mlruns

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# NOTES:
# - All passwords and secrets should be changed in production
# - Database passwords should match docker-compose.yml configuration
# - External URLs (NEXT_PUBLIC_*) use localhost for browser access
# - Internal URLs use Docker service names for inter-container communication
# =============================================================================
