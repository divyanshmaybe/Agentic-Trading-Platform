civo_region  = "mum1"
cluster_name = "civo-k8s-cluster"
node_size    = "g4s.kube.medium"
node_count   = 3

# Cloudflare Configuration for External-DNS
cloudflare_api_token = "your-cloudflare-api-token-here"
cloudflare_zone_id   = "your-cloudflare-zone-id-here"

# Let's Encrypt Configuration
letsencrypt_email = "your-email@example.com"

# AWS (for Thanos S3 object storage)
aws_region            = "ap-south-1"
# Provide one of the following methods for AWS credentials:
# 1) Leave these empty and use environment variables or AWS profile
# 2) Fill these values here (they are sensitive; ensure tfvars is not committed)
aws_access_key_id     = "YOUR_AWS_ACCESS_KEY_ID"
aws_secret_access_key = "YOUR_AWS_SECRET_ACCESS_KEY"
# aws_session_token   = "YOUR_AWS_SESSION_TOKEN" # optional

# Thanos S3 bucket
thanos_s3_bucket_name = "terraform-k8s-thanos-metrics"

# ArgoCD GitHub Repository Credentials (optional)
# Leave empty to skip creating the secret
argocd_github_repo_url      = "https://github.com/aayush0325/kubernetes-basics.git"
argocd_github_repo_password = "ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXX"
argocd_github_username      = "aayush0325"
