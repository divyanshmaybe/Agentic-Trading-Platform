{
  "dashboard": {
    "title": "Celery Workers - Trading Platform",
    "tags": ["celery", "trading", "workers"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Worker Status",
        "type": "stat",
        "targets": [
          {
            "expr": "celery_worker_up",
            "legendFormat": "{{worker}}"
          }
        ],
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Tasks Per Second",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(celery_tasks_total[1m])",
            "legendFormat": "{{worker}} - {{task_name}} ({{status}})"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
      },
      {
        "id": 3,
        "title": "Active Tasks",
        "type": "graph",
        "targets": [
          {
            "expr": "celery_worker_tasks_active",
            "legendFormat": "{{worker}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
      },
      {
        "id": 4,
        "title": "Task Duration (95th percentile)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(celery_task_duration_seconds_bucket[5m]))",
            "legendFormat": "{{worker}} - {{task_name}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12}
      },
      {
        "id": 5,
        "title": "Success Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(celery_task_succeeded_total[5m]) / (rate(celery_task_succeeded_total[5m]) + rate(celery_task_failed_total[5m]))",
            "legendFormat": "{{worker}} - {{task_name}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12}
      },
      {
        "id": 6,
        "title": "Failed Tasks",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(celery_task_failed_total[1m])",
            "legendFormat": "{{worker}} - {{task_name}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20}
      },
      {
        "id": 7,
        "title": "Task Retries",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(celery_task_retried_total[1m])",
            "legendFormat": "{{worker}} - {{task_name}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20}
      }
    ]
  }
}
