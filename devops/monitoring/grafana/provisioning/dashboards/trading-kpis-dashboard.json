        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "(sum(celery_task_runtime_sum) / sum(celery_task_runtime_count)) or vector(0)",
          "legendFormat": "Avg",
          "refId": "A"
        }
      ],
      "title": "⏱️ Avg Task Latency",
      "type": "gauge"
    },
