      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "expr": "histogram_quantile(0.99, sum(rate(portfolio_trade_execution_latency_seconds_bucket[5m])) by (le)) or (sum(celery_task_runtime_sum{name=~\"trading.*\"}) / sum(celery_task_runtime_count{name=~\"trading.*\"}))",
          "legendFormat": "P99",
          "refId": "A"
        }
      ],
      "title": "⏱️ P99 Trade Latency",
      "type": "gauge"
    },
